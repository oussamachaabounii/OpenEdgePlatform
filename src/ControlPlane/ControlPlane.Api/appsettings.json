{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "MassTransit": "Warning",
        "Grpc": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Database=edge_platform_control;Username=postgres;Password=postgres",
    "RabbitMq": "amqp://guest:guest@rabbitmq:5672",
    "Redis": "redis:6379"
  },
  "ControlPlane": {
    "GrpcPort": 18000,
    "RestPort": 8081,
    "SnapshotCacheTtl": "00:05:00",
    "EnableRedisCache": true
  },
  "RunMigrationsOnStartup": true,
  "AllowedHosts": "*"
}
