{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "MassTransit": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Database=edge_platform;Username=postgres;Password=postgres",
    "RabbitMq": "amqp://guest:guest@rabbitmq:5672"
  },
  "Provisioning": {
    "AvailableRegions": ["us-east-1", "us-west-2", "eu-west-1"],
    "RegionsPerInstance": 2,
    "MaxEndpointsPerService": 32
  }
}
