{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "MassTransit": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Database=edge_platform;Username=postgres;Password=postgres",
    "RabbitMq": "amqp://guest:guest@rabbitmq:5672"
  },
  "RunMigrationsOnStartup": true,
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": { "Url": "http://0.0.0.0:8080" }
    }
  }
}
